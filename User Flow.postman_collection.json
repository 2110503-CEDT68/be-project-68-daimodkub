    {
      "name": "User Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "const status = pm.response.code;",
              "",
              "if (status === 200) {",
              "    pm.test(\"User booking created\", () => {",
              "        pm.expect(res.success).to.be.true;",
              "    });",
              "",
              "    if (res.data && res.data._id) {",
              "        pm.environment.set(\"RESERVATION_ID\", res.data._id);",
              "    }",
              "",
              "    pm.execution.setNextRequest(\"User View Own Booking\");",
              "}",
              "",
              "else if (status === 400) {",
              "    pm.test(\"Booking rejected due to shop hours\", () => {",
              "        pm.expect(res.success).to.be.false;",
              "        pm.expect(res.message).to.include(\"only open\");",
              "    });",
              "",
              "    console.warn(\"User booking failed:\", res.message);",
              "",
              "    pm.execution.setNextRequest(\"User View Own Booking\");",
              "}",
              "",
              "else {",
              "    pm.test(\"Unexpected status\", () => {",
              "        pm.expect.fail(`Unexpected status: ${status}`);",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randomDays = Math.floor(Math.random() * 30) + 1;",
              "const randomHour = Math.floor(Math.random() * 8) + 10;",
              "",
              "let bookingDate = new Date();",
              "bookingDate.setDate(bookingDate.getDate() + randomDays);",
              "bookingDate.setHours(randomHour, 0, 0, 0);",
              "",
              "pm.variables.set(\"random_booking_date\", bookingDate.toISOString());",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{USER_TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"date\": \"{{random_booking_date}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{URL}}/api/v1/massageShops/{{MASSAGE_SHOP_ID}}/reservations",

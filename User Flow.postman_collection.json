  "item": [
    {
      "name": "User Registration",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"200 OK\", () => pm.response.to.have.status(200));",
              "",
              "pm.execution.setNextRequest(\"User Log-in\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const uuid = pm.variables.replaceIn('{{$guid}}');",
              "",
              "pm.environment.set(\"name\", \"user_\" + uuid);",
              "pm.environment.set(\"email\", `user_${uuid}@gmail.com`);",
              "pm.environment.set(\"tel\", \"08\" + uuid.substring(0,8));",
              "pm.environment.set(\"password\", \"password\");",
              "pm.environment.set(\"role\", \"user\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"{{name}}\",\n    \"tel\": \"{{tel}}\",\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\",\n    \"role\": \"{{role}}\"\n}\n// {\n//     \"name\": \"test_user\",\n//     \"tel\": \"12345678\",\n//     \"email\": \"testuser@gmail.com\",\n//     \"password\": \"password\",\n//     \"role\": \"user\"\n\n//     // \"name\": \"test_admin\",\n//     // \"tel\": \"12345678\",\n//     // \"email\": \"testadmin@gmail.com\",\n//     // \"password\": \"password\",\n//     // \"role\": \"admin\"\n// }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{URL}}/api/v1/auth/register",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },

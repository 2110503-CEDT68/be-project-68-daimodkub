    {
      "name": "User View Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "pm.environment.set(\"MASSAGE_SHOP_ID\", jsonData.data[0]._id);",
              "",
              "pm.test(\"200 OK\", () => pm.response.to.have.status(200));",
              "",
              "const res = pm.response.json();",
              "pm.expect(res.count).to.be.above(0);",
              "",
              "pm.execution.setNextRequest(\"User Create Booking\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{URL}}/api/v1/massageShops",
